# Varlock-generated env types (regenerated by the `typegen` task)
env.d.ts

# Build output
dist/
# Bundled preload (generated by the `preload` pack task from electron/preload.ts)
electron/preload.bundle.cjs

# Playwright
test-results/
playwright-report/

# local env files — real secrets stay out of git; .env.schema is the
# committed contract varlock's typegen reads (CI has no real .env).
.env
.env*.local
!.env.schema
