# Varlock-generated env types (regenerated by the `typegen` task)
env.d.ts

# Build output
dist/

# The SEA-compiled sidecar binary (generated by `vp pack` → name-sidecar.mjs)
src-tauri/binaries/discord-sidecar*

# Tauri build artifacts
src-tauri/target/
src-tauri/gen/

# Playwright smoke output (e2e/*.smoke.ts)
test-results/
playwright-report/

# local env files — real secrets stay out of git; .env.schema is the
# committed contract varlock's typegen reads (CI has no real .env).
.env
.env*.local
!.env.schema
