{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Friends List Studio",
  "version": "0.1.0",
  "identifier": "gg.saeris.discordkit.friends-list-studio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:3400",
    "beforeDevCommand": "vp dev",
    "beforeBuildCommand": "vp build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Friends List Studio",
        "width": 960,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/discord-sidecar"],
    "resources": {
      "binaries/koffi": "koffi"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
