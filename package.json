{
  "name": "discordkit",
  "description": "A REST API Client for Discord",
  "version": "0.0.1",
  "license": "MIT",
  "engines": {
    "node": ">=20.x"
  },
  "packageManager": "yarn@4.15.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "examples/*",
    "packages/*"
  ],
  "resolutions": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "type": "module",
  "scripts": {
    "clean": "rimraf --glob packages/*/dist",
    "format": "vp run lint --fix",
    "test": "vp test --fileParallelism",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@tanstack/react-query": "^5.100.14",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@trpc/server": "^11.17.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.7",
    "happy-dom": "^20.9.0",
    "msw": "^2.14.6",
    "nodejs-snowflake": "^2.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rimraf": "^6.1.3",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3",
    "valibot": "^1.4.0",
    "valimock": "^1.4.0",
    "vitest": "catalog:"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "vite-plus": "catalog:"
  }
}
