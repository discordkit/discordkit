{
  "name": "discordkit",
  "description": "A REST API Client for Discord",
  "version": "0.0.1",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "yarn@4.17.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "examples/*",
    "packages/*"
  ],
  "resolutions": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "@next/env": "npm:@varlock/nextjs-integration@^1.1.3"
  },
  "type": "module",
  "scripts": {
    "format": "vp run lint --fix",
    "test": "vp test --fileParallelism",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@trpc/server": "^11.17.0",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/coverage-v8": "^4.1.7",
    "happy-dom": "^20.9.0",
    "msw": "catalog:",
    "nodejs-snowflake": "^2.0.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rimraf": "^6.1.3",
    "typescript": "catalog:",
    "valibot": "catalog:",
    "valimock": "1.6.0",
    "vitest": "catalog:"
  },
  "devDependencies": {
    "@saeris/configs": "1.6.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "mdast-util-to-string": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "vite-plus": "^0.1.24"
  }
}
