{
  "name": "@discordkit/client",
  "description": "A REST API Client for Discord",
  "version": "4.1.0",
  "license": "MIT",
  "author": "Drake Costa <drake@saeris.gg> (https://saeris.gg)",
  "keywords": [
    "discord",
    "api",
    "client",
    "rest",
    "trpc",
    "react-query"
  ],
  "homepage": "https://github.com/discordkit/discordkit#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/discordkit/discordkit.git",
    "directory": "packages/client"
  },
  "bugs": {
    "url": "https://github.com/discordkit/discordkit/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "prepack": "node -e \"require('node:fs').copyFileSync(require('node:path').join('..','..','README.md'),'README.md')\""
  },
  "type": "module",
  "imports": {
    "#mocks": "./src/__mocks__/mockSchema.mock.ts"
  },
  "exports": {
    ".": {
      "@discordkit/source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./*": {
      "@discordkit/source": "./src/*.ts",
      "types": "./dist/*.d.mts",
      "import": "./dist/*.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*"
  ],
  "sideEffects": false,
  "dependencies": {
    "@discordkit/core": "workspace:^"
  },
  "devDependencies": {
    "@discordkit/test-utils": "workspace:^"
  },
  "peerDependencies": {
    "valibot": ">= 1.4.0"
  }
}
