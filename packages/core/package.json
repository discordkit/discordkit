{
  "name": "@discordkit/core",
  "description": "Core utility functions for Discordkit",
  "version": "4.0.1",
  "license": "MIT",
  "author": "Drake Costa <drake@saeris.gg> (https://saeris.gg)",
  "keywords": [
    "discordkit",
    "core",
    "utilities"
  ],
  "homepage": "https://github.com/discordkit/discordkit#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/discordkit/discordkit.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "type": "module",
  "exports": {
    ".": {
      "@discordkit/source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./*": {
      "@discordkit/source": "./src/*.ts",
      "types": "./dist/*.d.mts",
      "import": "./dist/*.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "valibot": ">= 1.4.0"
  },
  "devDependencies": {
    "@discordkit/test-utils": "workspace:^"
  }
}
