{
  "name": "@discordkit/native",
  "description": "Functional TypeScript bridge to the Discord Social SDK for Electron, Tauri, and other native desktop runtimes",
  "version": "0.1.0",
  "license": "MIT",
  "author": "Drake Costa <drake@saeris.gg> (https://saeris.gg)",
  "keywords": [
    "discord",
    "social-sdk",
    "rich-presence",
    "electron",
    "tauri",
    "ffi",
    "native"
  ],
  "homepage": "https://github.com/discordkit/discordkit#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/discordkit/discordkit.git",
    "directory": "packages/native"
  },
  "bugs": {
    "url": "https://github.com/discordkit/discordkit/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "type": "module",
  "exports": {
    ".": {
      "@discordkit/source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./presence": {
      "@discordkit/source": "./src/presence/index.ts",
      "types": "./dist/presence/index.d.mts",
      "import": "./dist/presence/index.mjs"
    },
    "./users": {
      "@discordkit/source": "./src/users/index.ts",
      "types": "./dist/users/index.d.mts",
      "import": "./dist/users/index.mjs"
    },
    "./*": {
      "@discordkit/source": "./src/*.ts",
      "types": "./dist/*.d.mts",
      "import": "./dist/*.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*"
  ],
  "sideEffects": false,
  "dependencies": {
    "koffi": "catalog:",
    "signal-polyfill": "catalog:"
  }
}
