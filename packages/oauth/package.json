{
  "name": "@discordkit/oauth",
  "description": "Framework-agnostic Discord OAuth2 utilities",
  "version": "0.0.0",
  "license": "MIT",
  "author": "Drake Costa <drake@saeris.gg> (https://saeris.gg)",
  "keywords": [
    "discord",
    "oauth",
    "oauth2",
    "auth",
    "pkce"
  ],
  "homepage": "https://github.com/discordkit/discordkit#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/discordkit/discordkit.git",
    "directory": "packages/oauth"
  },
  "bugs": {
    "url": "https://github.com/discordkit/discordkit/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "type": "module",
  "exports": {
    ".": {
      "@discordkit/source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./*": {
      "@discordkit/source": "./src/*.ts",
      "types": "./dist/*.d.mts",
      "import": "./dist/*.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*"
  ],
  "sideEffects": false,
  "devDependencies": {
    "@discordkit/test-utils": "workspace:^"
  }
}
